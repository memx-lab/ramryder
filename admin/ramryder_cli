#!/usr/bin/env python3
import argparse
import json
import os
import random
import shlex
import socket
import subprocess
import sys
import time
from dataclasses import dataclass
from typing import Dict, List, Tuple
from resource_mngr_rpc import ResourceClient

BASE_PORT = 2806
VM_NAME_PREFIX = "RAMRYDER-VM"
RC = ResourceClient()


@dataclass
class VmConfig:
    memory_mb: int
    channels: int
    cxl_memory_mb: int
    cxl_channels: int
    cpu_set: str
    image: str
    hostfwd_port: int
    disable_vcpu_pin: bool
    dry_run: bool


@dataclass
class MemPoolNode:
    node_id: int
    tier_id: int
    free_mb: int


def parse_memory_to_mb(raw: str) -> int:
    s = raw.strip().lower()
    if s.endswith("gb"):
        return int(s[:-2]) * 1024
    if s.endswith("g"):
        return int(s[:-1]) * 1024
    if s.endswith("mb"):
        return int(s[:-2])
    if s.endswith("m"):
        return int(s[:-1])
    return int(s)


def parse_cpu_set(cpu_set: str) -> List[int]:
    cpus = set()
    for part in cpu_set.split(","):
        part = part.strip()
        if not part:
            continue
        if "-" in part:
            start_s, end_s = part.split("-", 1)
            start = int(start_s)
            end = int(end_s)
            if end < start:
                raise ValueError(f"Invalid cpu range: {part}")
            cpus.update(range(start, end + 1))
        else:
            cpus.add(int(part))
    if not cpus:
        raise ValueError("cpu-set resolves to empty CPU list")
    return sorted(cpus)


def expand_cpu_list(cpu_set: str) -> List[int]:
    cpus: List[int] = []
    for part in cpu_set.split(","):
        part = part.strip()
        if not part:
            continue
        if "-" in part:
            start_s, end_s = part.split("-", 1)
            start = int(start_s)
            end = int(end_s)
            if end < start:
                raise ValueError(f"Invalid CPU range: {part}")
            cpus.extend(range(start, end + 1))
        else:
            cpus.append(int(part))
    return cpus


def split_memory(total_mb: int, channels: int) -> List[int]:
    base = total_mb // channels
    rem = total_mb % channels
    result = [base] * channels
    for i in range(rem):
        result[i] += 1
    return result


def run_cmd(cmd: List[str], dry_run: bool) -> str:
    printable = " ".join(shlex.quote(x) for x in cmd)
    print(f"[cmd] {printable}")
    if dry_run:
        return ""
    proc = subprocess.run(cmd, capture_output=True, text=True)
    if proc.returncode != 0:
        if proc.stdout:
            print(proc.stdout.strip(), file=sys.stderr)
        if proc.stderr:
            print(proc.stderr.strip(), file=sys.stderr)
        raise RuntimeError(f"Command failed ({proc.returncode}): {printable}")
    return proc.stdout.strip()


def run_cmd_capture(cmd: List[str]) -> str:
    proc = subprocess.run(cmd, capture_output=True, text=True)
    out = (proc.stdout or "").strip()
    err = (proc.stderr or "").strip()
    return out if out else err


def find_qemu_pids_by_vmid(vmid: int) -> List[int]:
    pattern = f"qemu-system-x86_64.*-name {VM_NAME_PREFIX}-{vmid}"
    proc = subprocess.run(["pgrep", "-f", pattern], capture_output=True, text=True)
    if proc.returncode != 0:
        return []
    pids: List[int] = []
    for line in (proc.stdout or "").splitlines():
        line = line.strip()
        if not line:
            continue
        try:
            pids.append(int(line))
        except ValueError:
            continue
    return pids


def get_used_vm_ids() -> List[int]:
    output = RC.get_vms()
    used = set()
    for line in output.splitlines():
        line = line.strip()
        if not line.startswith("VM id="):
            continue
        token = line.split()[1]
        if not token.startswith("id="):
            continue
        try:
            used.add(int(token.split("=", 1)[1]))
        except ValueError:
            continue
    return sorted(used)


def get_mem_pool_nodes() -> List[MemPoolNode]:
    output = RC.get_mem_pool()
    nodes: List[MemPoolNode] = []
    for raw in output.splitlines():
        line = raw.strip()
        if not line or line.startswith("Index"):
            continue
        parts = [p.strip() for p in line.split("|")]
        if len(parts) < 9:
            continue
        try:
            segment_mb = int(parts[3])
            used_seg = int(parts[4])
            total_seg = int(parts[5])
            node_id = int(parts[6])
            tier_id = int(parts[7])
        except ValueError:
            continue
        free_seg = total_seg - used_seg
        free_mb = free_seg * segment_mb
        nodes.append(MemPoolNode(node_id=node_id, tier_id=tier_id, free_mb=free_mb))
    if not nodes:
        raise RuntimeError("failed to parse nodes from get-mem-pool output")
    nodes.sort(key=lambda n: n.node_id)
    return nodes


def build_paths() -> Tuple[str, str]:
    script_dir = os.path.dirname(os.path.abspath(__file__))
    project_root = os.path.dirname(script_dir)
    qemu_bin = os.path.join(project_root, "qemu", "build", "qemu-system-x86_64")
    default_img = os.path.join(os.path.expanduser("~"), "images", "nvcloud-image-clean.qcow2")
    return qemu_bin, default_img


def get_vcpu_threads_from_qmp(qmp_sock: str) -> List[Tuple[int, int]]:
    payload = '{"execute":"qmp_capabilities"}\n{"execute":"query-cpus-fast"}\n'
    proc = subprocess.run(
        ["sudo", "nc", "-U", "-q", "1", qmp_sock],
        input=payload,
        capture_output=True,
        text=True,
        check=False,
    )
    if proc.returncode != 0:
        err = (proc.stderr or "").strip()
        raise RuntimeError(f"QMP query failed: {err or proc.returncode}")

    rows: List[Tuple[int, int]] = []
    for line in (proc.stdout or "").splitlines():
        line = line.strip()
        if not line:
            continue
        try:
            msg = json.loads(line)
        except json.JSONDecodeError:
            continue
        if "return" in msg and isinstance(msg["return"], list):
            for item in msg["return"]:
                rows.append((int(item["cpu-index"]), int(item["thread-id"])))
            break

    if not rows:
        raise RuntimeError("Could not read vCPU thread IDs from QMP")
    rows.sort(key=lambda x: x[0])
    return rows


def pin_qemu_vcpus(vmid: int, cpu_set: str) -> None:
    qmp_sock = f"/var/run/qmp-sock-{vmid}"
    host_cpus = expand_cpu_list(cpu_set)
    vcpu_threads = get_vcpu_threads_from_qmp(qmp_sock)
    if len(host_cpus) < len(vcpu_threads):
        raise RuntimeError(
            f"Not enough host CPUs for pinning: got {len(host_cpus)}, need {len(vcpu_threads)}"
        )
    for i, (_vcpu, tid) in enumerate(vcpu_threads):
        cpu = host_cpus[i]
        subprocess.run(
            ["sudo", "taskset", "-pc", str(cpu), str(tid)],
            check=True,
            capture_output=True,
            text=True,
        )


def wait_for_vm_ready(vmid: int, qemu_pid: int, ssh_port: int, timeout_s: int = 120) -> None:
    deadline = time.time() + timeout_s
    print("[info] waiting for VM ready...")
    while time.time() < deadline:
        try:
            os.kill(qemu_pid, 0)
            with socket.create_connection(("127.0.0.1", ssh_port), timeout=1.0) as sock:
                sock.settimeout(1.0)
                banner = sock.recv(64)
                if banner.startswith(b"SSH-"):
                    return
        except Exception:
            time.sleep(1.0)
    raise RuntimeError(
        f"[info] timeout: VM did not become ready within {timeout_s}s "
        f"(vmid={vmid}, port={ssh_port})"
    )


def to_m_arg(memory_mb: int) -> str:
    if memory_mb % 1024 == 0:
        return f"{memory_mb // 1024}G"
    return f"{memory_mb}M"


def is_tcp_port_in_use(port: int) -> bool:
    with socket.socket(socket.AF_INET, socket.SOCK_STREAM) as sock:
        sock.setsockopt(socket.SOL_SOCKET, socket.SO_REUSEADDR, 1)
        try:
            sock.bind(("0.0.0.0", port))
            return False
        except OSError:
            return True


def build_parser(default_img: str) -> argparse.ArgumentParser:
    parser = argparse.ArgumentParser(description="RamRyder Resource Manager (RM) CLI")
    subparsers = parser.add_subparsers(dest="command", required=True)

    create_parser = subparsers.add_parser("create-vm", help="Create and launch a VM")
    create_parser.add_argument("--cpu-set", required=True, help="Host CPU set, e.g. 0-9,20-29")
    create_parser.add_argument("--memory", required=True, help="Local memory (DIMM) in MB or GB (e.g. 153600M, 150G)")
    create_parser.add_argument("--channels", required=True, type=int, help="DIMM channel count")
    create_parser.add_argument("--cxl-memory", help="CXL memory in MB or GB (e.g. 51200M, 50G)")
    create_parser.add_argument("--cxl-channels", type=int, help="CXL channel count")
    create_parser.add_argument("--image", default=default_img, help="VM image path")
    create_parser.add_argument("--hostfwd-port", type=int, help="Host forwarded SSH port (default: base port + VMID)")
    create_parser.add_argument("--disable-vcpu-pin", action="store_true", help="Disable vCPU pinning")
    create_parser.add_argument("--dry-run", action="store_true", help="Execute RPC steps but do not launch final QEMU process")

    destroy_parser = subparsers.add_parser("destroy-vm", help="Destroy a VM and release resources")
    destroy_parser.add_argument("--vmid", required=True, type=int, help="VM ID to destroy")

    attach_parser = subparsers.add_parser("attach-mem", help="Allocate and hotplug memory to an existing VM")
    attach_parser.add_argument("--vmid", required=True, type=int, help="Target VM ID")
    attach_parser.add_argument("--memory", default="0M", help="Local memory (DIMM) in MB or GB (e.g. 1024M, 1G). Optional; default is 0M.")
    attach_parser.add_argument("--channels", type=int, default=0, help="Local memory channel count. 0 means use existing allocated channels")
    attach_parser.add_argument("--cxl-memory", help="CXL memory in MB or GB (e.g. 1024M, 1G)")
    attach_parser.add_argument("--cxl-channels", type=int, default=0, help="CXL channel count. 0 means use existing allocated channels")

    detach_parser = subparsers.add_parser("detach-mem", help="Hotunplug memory from VM and release pool allocation")
    detach_parser.add_argument("--vmid", required=True, type=int, help="Target VM ID")
    detach_parser.add_argument("--memid", required=True, type=int, help="Memory device ID (memX -> X)")

    query_parser = subparsers.add_parser("query", help="Query resource manager state")
    query_parser.add_argument("--type", required=True, choices=["mempool", "vm"], help="Query target: mempool or vm")

    return parser


def select_vmid() -> int:
    existing_vmids = get_used_vm_ids()
    if existing_vmids:
        print(f"[info] existing vm ids: {','.join(str(v) for v in existing_vmids)}")
    else:
        print("[info] existing vm ids: (none detected)")
    used = set(existing_vmids)
    vmid = 0
    while vmid in used:
        vmid += 1
    return vmid


def select_hostfwd_port(requested: int, vmid: int) -> int:
    if requested is not None:
        return requested
    port = BASE_PORT + vmid
    if not is_tcp_port_in_use(port):
        return port
    for _ in range(128):
        candidate = port + random.randint(1, 2000)
        if not is_tcp_port_in_use(candidate):
            return candidate
    raise RuntimeError("failed to find a free hostfwd port")


def choose_allocations_for_tier(
    tier_nodes: List[MemPoolNode],
    requested_sizes_mb: List[int],
    memory_name: str,
) -> List[Tuple[int, int]]:
    channels = len(requested_sizes_mb)
    if channels == 0:
        return []

    if channels > len(tier_nodes):
        raise ValueError(
            f"{memory_name} channels ({channels}) must be <= available channels ({len(tier_nodes)})"
        )

    # Greedy matching: large requests first, assign to nodes with enough free capacity.
    sizes_sorted = sorted(requested_sizes_mb, reverse=True)
    candidate_nodes = sorted(tier_nodes, key=lambda n: n.free_mb, reverse=True)
    used_node_ids = set()
    selected: List[Tuple[int, int]] = []
    for size_mb in sizes_sorted:
        picked = None
        for node in candidate_nodes:
            if node.node_id in used_node_ids:
                continue
            if node.free_mb >= size_mb:
                picked = node
                break
        if picked is None:
            max_free = max((n.free_mb for n in candidate_nodes if n.node_id not in used_node_ids), default=0)
            raise ValueError(
                f"{memory_name} capacity is not enough: need per-channel up to {size_mb}MB, "
                f"but largest remaining free channel is {max_free}MB"
            )
        used_node_ids.add(picked.node_id)
        selected.append((picked.node_id, size_mb))

    # Deterministic order by node id for stable command lines.
    selected.sort(key=lambda x: x[0])
    return selected


def get_vm_mem_nodes(vmid: int) -> List[int]:
    output = RC.get_vms()
    in_target = False
    nodes: List[int] = []
    for raw in output.splitlines():
        line = raw.strip()
        if line.startswith("VM id="):
            in_target = line.startswith(f"VM id={vmid} ")
            continue
        if in_target and line.startswith("memdev="):
            parts = line.split()
            for p in parts:
                if p.startswith("node="):
                    try:
                        nodes.append(int(p.split("=", 1)[1]))
                    except ValueError:
                        pass
                    break
    return sorted(set(nodes))


def choose_allocations_for_tier_attach(
    tier_nodes: List[MemPoolNode],
    requested_memory_mb: int,
    requested_channels: int,
    existing_vm_nodes: List[int],
    memory_name: str,
) -> List[Tuple[int, int]]:
    if requested_memory_mb <= 0:
        return []

    tier_node_ids = {n.node_id for n in tier_nodes}
    existing_nodes_in_tier = sorted([nid for nid in existing_vm_nodes if nid in tier_node_ids])

    if requested_channels == 0:
        if not existing_nodes_in_tier:
            raise ValueError(
                f"{memory_name} channels=0 requires existing allocated channels on this tier"
            )
        selected_nodes = [n for n in tier_nodes if n.node_id in existing_nodes_in_tier]
        channel_count = len(selected_nodes)
    else:
        if requested_channels < 0:
            raise ValueError(f"{memory_name} channels must be >= 0")
        selected_nodes = [n for n in tier_nodes if n.node_id not in existing_nodes_in_tier]
        channel_count = requested_channels
        if channel_count > len(selected_nodes):
            raise ValueError(
                f"{memory_name} channels ({channel_count}) must be <= available NEW channels ({len(selected_nodes)})"
            )
        # limit to the top free channels for better fit
        selected_nodes = sorted(selected_nodes, key=lambda n: n.free_mb, reverse=True)[:channel_count]

    if requested_memory_mb < channel_count:
        raise ValueError(f"{memory_name} memory is too small for selected channels")

    sizes = split_memory(requested_memory_mb, channel_count)
    return choose_allocations_for_tier(selected_nodes, sizes, memory_name)


def build_memory_plan(cfg: VmConfig) -> Tuple[List[int], List[Tuple[int, int]], int, int]:
    pool_nodes = get_mem_pool_nodes()
    all_node_ids = sorted({n.node_id for n in pool_nodes})
    tier0_nodes = [n for n in pool_nodes if n.tier_id == 0]
    tier1_nodes = [n for n in pool_nodes if n.tier_id == 1]

    allocations: List[Tuple[int, int]] = []
    tier0_sizes = split_memory(cfg.memory_mb, cfg.channels)
    tier0_allocations = choose_allocations_for_tier(tier0_nodes, tier0_sizes, "local memory (DIMM)")
    for item in tier0_allocations:
        allocations.append(item)

    if cfg.cxl_channels > 0:
        tier1_sizes = split_memory(cfg.cxl_memory_mb, cfg.cxl_channels)
        tier1_allocations = choose_allocations_for_tier(tier1_nodes, tier1_sizes, "CXL memory")
        for item in tier1_allocations:
            allocations.append(item)

    return all_node_ids, allocations, len(tier0_nodes), len(tier1_nodes)


def build_qemu_cmd(
    qemu_bin: str,
    cfg: VmConfig,
    vmid: int,
    smp: int,
    node0_vcpu_range: str,
    hostfwd_port: int,
    all_node_ids: List[int],
    allocations: List[Tuple[int, int]],
) -> List[str]:
    name = f"{VM_NAME_PREFIX}-{vmid}"
    sock_path = "/var/run"
    qmp_sock = f"{sock_path}/qmp-sock-{vmid}"
    qga_sock = f"{sock_path}/qga-sock-{vmid}"

    mem_args: List[str] = []
    node_args: List[str] = []

    node_to_memid: Dict[int, str] = {}
    for node_id, size_mb in allocations:
        out = RC.alloc_mem(node_id, vmid, size_mb)
        if not out:
            raise RuntimeError("alloc-mem returned empty output; cannot build memdev argument")

        mem_id = None
        for part in out.split(","):
            part = part.strip()
            if part.startswith("id="):
                mem_id = part.split("=", 1)[1]
                break
        if not mem_id:
            raise RuntimeError(f"alloc-mem returned invalid id field: {out}")

        mem_args.append(f"-object memory-backend-file,share=on,{out}")
        node_to_memid[node_id] = mem_id

    first_mem_node = allocations[0][0] if allocations else None
    for node_id in all_node_ids:
        out = RC.get_node_info(node_id)
        if not out:
            raise RuntimeError("get-node-info returned empty output; cannot build numa node argument")
        base = f"-numa node,{out},seg-id=0"
        if node_id in node_to_memid:
            mem_id = node_to_memid[node_id]
            if node_id == first_mem_node:
                node_args.append(f"{base},memdev={mem_id},cpus={node0_vcpu_range}")
            else:
                node_args.append(f"{base},memdev={mem_id}")
        else:
            node_args.append(base)

    total_memory_mb = cfg.memory_mb + cfg.cxl_memory_mb
    qemu_cmd: List[str] = [
        "sudo",
        "taskset",
        "-c",
        cfg.cpu_set,
        qemu_bin,
        "-name",
        name,
        "-enable-kvm",
        "-cpu",
        "host",
        "-smp",
        str(smp),
        "-m",
        to_m_arg(total_memory_mb),
    ]

    for item in mem_args:
        qemu_cmd.extend(shlex.split(item))
    for item in node_args:
        qemu_cmd.extend(shlex.split(item))

    qemu_cmd.extend(
        [
            "-device",
            "virtio-scsi-pci,id=scsi0",
            "-device",
            "scsi-hd,drive=hd0",
            "-drive",
            f"file={cfg.image},if=none,aio=native,cache=none,format=qcow2,id=hd0",
            "-net",
            f"user,hostfwd=tcp::{hostfwd_port}-:22",
            "-net",
            "nic,model=virtio",
            "-nographic",
            "-qmp",
            f"unix:{qmp_sock},server,nowait",
            "-chardev",
            f"socket,path={qga_sock},server=on,wait=off,id=qga0",
            "-device",
            "virtio-serial",
            "-device",
            "virtserialport,chardev=qga0,name=org.qemu.guest_agent.0",
        ]
    )
    return qemu_cmd


def handle_destroy_vm(args: argparse.Namespace) -> int:
    vmid = args.vmid
    pids = find_qemu_pids_by_vmid(vmid)
    for pid in pids:
        subprocess.run(["sudo", "kill", "-15", str(pid)], check=False, capture_output=True, text=True)
    if pids:
        time.sleep(1.0)
        for pid in find_qemu_pids_by_vmid(vmid):
            subprocess.run(["sudo", "kill", "-9", str(pid)], check=False, capture_output=True, text=True)

    out = RC.destroy_vm(vmid)
    if "success" not in out.lower():
        raise RuntimeError(f"destroy-vm failed for vid={vmid}: {out}")

    print(f"[info] destroy success: vmid={vmid} qemu_killed={len(pids)}")
    return 0


def handle_create_vm(args: argparse.Namespace, qemu_bin: str) -> int:
    if args.cxl_memory is None and args.cxl_channels is not None:
        raise ValueError("--cxl-memory is required when --cxl-channels is set")
    if args.cxl_memory is not None and args.cxl_channels is None:
        raise ValueError("--cxl-channels is required when --cxl-memory is set")

    memory_mb = parse_memory_to_mb(args.memory)
    cxl_memory_mb = parse_memory_to_mb(args.cxl_memory) if args.cxl_memory else 0
    cxl_channels = args.cxl_channels if args.cxl_channels is not None else 0

    if args.channels <= 0:
        raise ValueError("--channels must be > 0")
    if memory_mb < args.channels:
        raise ValueError("local memory (DIMM) --memory is too small for --channels")
    if cxl_channels < 0:
        raise ValueError("--cxl-channels must be >= 0")
    if cxl_channels == 0 and cxl_memory_mb > 0:
        raise ValueError("--cxl-memory requires --cxl-channels > 0")
    if cxl_channels > 0 and cxl_memory_mb < cxl_channels:
        raise ValueError("CXL memory --cxl-memory is too small for --cxl-channels")

    cpus = parse_cpu_set(args.cpu_set)
    smp = len(cpus)
    node0_vcpu_range = f"0-{smp - 1}"

    cfg = VmConfig(
        memory_mb=memory_mb,
        channels=args.channels,
        cxl_memory_mb=cxl_memory_mb,
        cxl_channels=cxl_channels,
        cpu_set=args.cpu_set,
        image=args.image,
        hostfwd_port=args.hostfwd_port,
        disable_vcpu_pin=args.disable_vcpu_pin,
        dry_run=args.dry_run,
    )

    all_node_ids, allocations, tier0_count, tier1_count = build_memory_plan(cfg)
    print(f"[info] total available channels: {len(all_node_ids)}")
    print(f"[info] local memory (DIMM) channels: {tier0_count}")
    print(f"[info] CXL memory channels: {tier1_count}")

    vmid = select_vmid()
    create_out = RC.create_vm(vmid, cfg.cpu_set)
    if "success" not in create_out.lower():
        raise RuntimeError(f"create-vm failed for vid={vmid}: {create_out}")
    print(f"[info] selected vm id: {vmid}")

    hostfwd_port = select_hostfwd_port(cfg.hostfwd_port, vmid)
    print(f"[info] hostfwd port: {hostfwd_port}")

    qemu_started = False
    log_path = f"/tmp/ramryder-vm-{vmid}.log"

    try:
        qemu_cmd = build_qemu_cmd(
            qemu_bin=qemu_bin,
            cfg=cfg,
            vmid=vmid,
            smp=smp,
            node0_vcpu_range=node0_vcpu_range,
            hostfwd_port=hostfwd_port,
            all_node_ids=all_node_ids,
            allocations=allocations,
        )

        if cfg.dry_run:
            run_cmd(qemu_cmd, True)
        else:
            printable_qemu = " ".join(shlex.quote(x) for x in qemu_cmd)
            print(f"[cmd] {printable_qemu}")
            with open(log_path, "ab") as logf:
                proc = subprocess.Popen(
                    qemu_cmd,
                    stdin=subprocess.DEVNULL,
                    stdout=logf,
                    stderr=subprocess.STDOUT,
                    start_new_session=True,
                )

            time.sleep(1.0)
            ret = proc.poll()
            if ret is not None:
                print(f"[error] QEMU launch failed; check log: {log_path}", file=sys.stderr)
                raise RuntimeError(f"qemu exited early with code {ret}")

            qemu_started = True
            qemu_pids = find_qemu_pids_by_vmid(vmid)
            qemu_pid = qemu_pids[0] if qemu_pids else proc.pid
            print(f"[info] QEMU launch success: pid={qemu_pid} vmid={vmid} ssh_port={hostfwd_port} log_path={log_path}")
            wait_for_vm_ready(vmid, qemu_pid, hostfwd_port)
            if cfg.disable_vcpu_pin:
                print(f"[info] vCPU pin disabled: vmid={vmid}")
            else:
                try:
                    pin_qemu_vcpus(vmid, cfg.cpu_set)
                    print(f"[info] CPU pin success: vmid={vmid} cpu_set={cfg.cpu_set}")
                except Exception as pin_err:
                    print(f"[warn] vcpu pin failed for vmid={vmid}: {pin_err}", file=sys.stderr)
            print(f"[info] VM startup ready: SSH port={hostfwd_port}")
    finally:
        if cfg.dry_run or not qemu_started:
            try:
                _ = RC.destroy_vm(vmid)
            except Exception as cleanup_err:
                print(f"[warn] failed to destroy vm {vmid}: {cleanup_err}", file=sys.stderr)

    return 0


def handle_attach_mem(args: argparse.Namespace) -> int:
    if args.cxl_memory is None and args.cxl_channels != 0:
        raise ValueError("--cxl-memory is required when --cxl-channels is set")

    vmid = args.vmid
    local_memory_mb = parse_memory_to_mb(args.memory)
    local_channels = args.channels
    cxl_memory_mb = parse_memory_to_mb(args.cxl_memory) if args.cxl_memory else 0
    cxl_channels = args.cxl_channels

    if local_channels < 0:
        raise ValueError("--channels must be >= 0")
    if cxl_channels < 0:
        raise ValueError("--cxl-channels must be >= 0")
    if cxl_memory_mb == 0 and cxl_channels > 0:
        raise ValueError("--cxl-memory must be > 0 when --cxl-channels > 0")

    pool_nodes = get_mem_pool_nodes()
    tier0_nodes = [n for n in pool_nodes if n.tier_id == 0]
    tier1_nodes = [n for n in pool_nodes if n.tier_id == 1]
    existing_nodes = get_vm_mem_nodes(vmid)
    if not existing_nodes:
        raise ValueError(
            f"VM {vmid} has no allocated memory channels. Use --channels > 0 to add new channels."
        )

    allocations: List[Tuple[int, int]] = []
    local_allocations = choose_allocations_for_tier_attach(
        tier0_nodes, local_memory_mb, local_channels, existing_nodes, "local memory (DIMM)"
    )
    for item in local_allocations:
        allocations.append(item)

    cxl_allocations = choose_allocations_for_tier_attach(
        tier1_nodes, cxl_memory_mb, cxl_channels, existing_nodes, "CXL memory"
    )
    for item in cxl_allocations:
        allocations.append(item)
    if not allocations:
        raise ValueError("no memory requested to attach")

    allocated_memids: List[int] = []
    try:
        for node_id, size_mb in allocations:
            out = RC.alloc_mem(node_id, vmid, size_mb)
            mem_id_str = None
            for part in out.split(","):
                part = part.strip()
                if part.startswith("id="):
                    mem_id_str = part.split("=", 1)[1]
                    break
            if not mem_id_str or not mem_id_str.startswith("mem"):
                raise RuntimeError(f"alloc-mem returned invalid id field: {out}")
            memid = int(mem_id_str[3:])
            allocated_memids.append(memid)

            attach_out = RC.attach_mem(memid, vmid, node_id)
            if "success" not in attach_out.lower():
                raise RuntimeError(
                    f"attach-mem failed for vmid={vmid}, memid={memid}, nid={node_id}: {attach_out}"
                )

        memid_str = ",".join(str(m) for m in allocated_memids)
        print(f"[info] attach-mem success: vmid={vmid} allocations={len(allocations)} memids={memid_str}")
    except Exception:
        for memid in allocated_memids:
            try:
                _ = RC.free_mem(vmid, memid)
            except Exception:
                pass
        raise

    return 0


def handle_detach_mem(args: argparse.Namespace) -> int:
    vmid = args.vmid
    memid = args.memid

    detach_out = RC.detach_mem(memid, vmid)
    if "success" not in detach_out.lower():
        raise RuntimeError(
            f"detach-mem failed for vmid={vmid}, memid={memid}: {detach_out}"
        )

    free_out = RC.free_mem(vmid, memid)
    if "success" not in free_out.lower():
        raise RuntimeError(
            f"free-mem failed for vmid={vmid}, memid={memid}: {free_out}"
        )

    print(f"[info] detach-mem success: vmid={vmid} memid={memid}")
    return 0


def handle_query(args: argparse.Namespace) -> int:
    if args.type == "mempool":
        print(RC.get_mem_pool())
    elif args.type == "vm":
        print(RC.get_vms())
    else:
        raise ValueError(f"unknown query type: {args.type}")
    return 0


def main() -> int:
    qemu_bin, default_img = build_paths()
    parser = build_parser(default_img)
    args = parser.parse_args()

    if args.command == "create-vm":
        return handle_create_vm(args, qemu_bin)
    elif args.command == "destroy-vm":
        return handle_destroy_vm(args)
    elif args.command == "attach-mem":
        return handle_attach_mem(args)
    elif args.command == "detach-mem":
        return handle_detach_mem(args)
    elif args.command == "query":
        return handle_query(args)
    else:
        raise ValueError(f"unknown command: {args.command}")


if __name__ == "__main__":
    try:
        raise SystemExit(main())
    except Exception as exc:
        print(f"error: {exc}", file=sys.stderr)
        raise SystemExit(1)
